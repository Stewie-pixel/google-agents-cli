# DSA Mentor Agent — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Your Gemini API key from https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=your-gemini-api-key-here

# Required: Serper API key for YouTube video search
# Get one free at https://serper.dev
SERPER_API_KEY=your-serper-api-key-here
